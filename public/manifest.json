{
  "manifest_version": 3,
  "name": "FocusFlow",
  "description": "A study productivity app to stay consistent with deep work.",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "permissions": ["storage", "alarms", "notifications", "identity"],
  "browser_specific_settings": {
    "gecko": {
      "id": "focusflow-dev@aadu.com",
      "strict_min_version": "112.0",
      "data_collection_permissions": {
        "is_provided": false
      }
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/*.mp3", "sounds/*.ogg", "icon*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com"
  }
}
