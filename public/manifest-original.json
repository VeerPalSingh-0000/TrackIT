{
  "manifest_version": 3,
  "name": "FocusFlow",
  "description": "A study productivity app to stay consistent with deep work. Track sessions with Pomodoro and Stopwatch even when the popup is closed.",
  "version": "1.0.0",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open FocusFlow"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "alarms", "notifications", "identity"],
  "oauth2": {
    "client_id": "573843213419-lva274vejkjeq1v2rck584oskt6rcic5.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile",
      "openid"
    ]
  },
  "icons": {
    "16": "clock.png",
    "48": "clock.png",
    "128": "clock.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/*.mp3", "sounds/*.ogg", "clock.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com"
  }
}
